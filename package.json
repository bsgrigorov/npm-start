{
  "name": "@bsgrigorov/npm-start",
  "version": "0.0.0",
  "private": true,
  "description": "pnpm monorepo starter for publishing scoped npm packages",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "prettier": "^3.8.1",
    "turbo": "^2.8.12"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.32.0"
}
